DATABASE_URL=jdbc:postgresql://localhost:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=$2a$10$replace_with_bcrypt_hash
ADMIN_LOGIN_MAX_FAILED_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_MINUTES=15
ADMIN_LOGIN_CACHE_MAX_SIZE=1000
JWT_SECRET=replace_with_at_least_32_characters
JWT_EXPIRATION_MS=28800000
CORS_ALLOWED_ORIGINS=http://localhost:5173
SURVEY_PARTICIPANT_LIMIT=30
SURVEY_TEXT_RESPONSE_MAX_LENGTH=250
SURVEY_PARTICIPANT_COOKIE_NAME=participant_id
SURVEY_PARTICIPANT_COOKIE_MAX_AGE_DAYS=30
SURVEY_EXPORT_FILENAME=CafeRater_Analytics.csv
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PATH=/submit-category
RATE_LIMIT_WINDOW_SECONDS=15
RATE_LIMIT_MAX_SIZE=10000
RATE_LIMIT_MESSAGE=Please wait a few seconds before submitting again.
SEEDERS_ENABLED=true
SEEDERS_QUESTIONS_PATH=classpath:seed/questions.json
SEEDERS_MENU_ITEMS_PATH=classpath:seed/menu-items.json